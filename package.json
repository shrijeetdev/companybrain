{
  "name": "companybrain",
  "version": "0.1.0",
  "private": true,
  "description": "Team operating system that watches every channel and never lets a loop slip.",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "packages/*",
    "cli"
  ],
  "scripts": {
    "dev": "tsx cli/bin/companybrain.ts",
    "start": "tsx cli/bin/companybrain.ts",
    "build": "pnpm typecheck",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test packages/core/test/domain.test.ts packages/core/test/autonomy.test.ts packages/core/test/undo.test.ts packages/integrations/test/pipeline.test.ts"
  },
  "pnpm": {
    "overrides": {
      "esbuild": "npm:esbuild-wasm@0.28.1"
    }
  },
  "devDependencies": {
    "@types/node": "^20",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
