# Deployment mode — the ONLY switch the codebase branches on.
# local = SQLite + in-process worker + single user (npx path, no Docker)
# selfhost = Postgres + Redis/BullMQ + org RBAC (docker compose)
# cloud = selfhost + Stripe billing + multi-tenant RLS
COMPANYBRAIN_MODE=local

# Port the local web/API listens on
COMPANYBRAIN_PORT=4317

# --- selfhost / cloud only (ignored in local mode) ---
DATABASE_URL=postgres://user:pass@localhost:5432/companybrain
REDIS_URL=redis://localhost:6379

# --- integrations (server-side only; never shipped to the client) ---
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=

# --- LLM (server-side only) ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
