# companybrain — one self-contained app. Copy to .env and fill what you need.
# Data lives in a single SQLite file (~/.companybrain/companybrain.sqlite). No DB/Redis to run.

# Port + host the app listens on. Default host 0.0.0.0 so it works on a server out of the box.
COMPANYBRAIN_PORT=4317
COMPANYBRAIN_HOST=0.0.0.0

# Optional: override where the SQLite file lives (e.g. a mounted volume on the server).
# COMPANYBRAIN_DB_PATH=/data/companybrain.sqlite

# --- integrations (server-side only; never shipped to the client) ---
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=

# --- LLM (server-side only) ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
